{
  "info": {
    "name": "Tempus AI",
    "_postman_id": "tempus-ai-collection",
    "description": "Tempus AI (NASDAQ: TEM) is a precision medicine company. As of this writing Tempus does not publish a self-serve, documented public developer API; its products (Lens, One, Hub, Next, ECG-AI, Pixel, xT/xR genomic profiling, Olivia) are delivered as enterprise and clinical SaaS via web apps and EHR integrations (HL7/FHIR). This collection therefore contains no API endpoints and instead links the public product documentation. It will be expanded if Tempus publishes a documented public API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
